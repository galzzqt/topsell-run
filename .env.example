# =============================================================
# TOPSELL-RUN — Environment Variables Template
# =============================================================
# Salin file ini ke .env (jangan pernah commit .env ke git!)
# Isi nilai yang sebenarnya di Dokploy → Environment Variables
# =============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Gunakan salah satu (SRV diutamakan)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI_STANDARD=mongodb://<user>:<pass>@<host>:27017/<dbname>
MONGODB_DB_NAME=topsell-run

# ── Session Secrets (isi dengan string acak panjang ≥ 32 char) ──
SESSION_SECRET=ganti-dengan-random-string-panjang
ADMIN_SESSION_SECRET=ganti-dengan-random-string-panjang
COMMUNITY_SESSION_SECRET=ganti-dengan-random-string-panjang
FAMILY_SESSION_SECRET=ganti-dengan-random-string-panjang

# ── Admin Accounts (login via env, bukan database) ───────────
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PASSWORD=ganti-dengan-password-kuat

ADMIN_USERNAME=admin
ADMIN_NAME=Admin
ADMIN_PASSWORD=ganti-dengan-password-kuat

# ── SMTP / Email ─────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=password-email-anda
SMTP_FROM=noreply@yourdomain.com

# ── Axiom Logging (opsional) ─────────────────────────────────
AXIOM_TOKEN=
AXIOM_DATASET=
AXIOM_ORG_ID=

# ── Binderbyte API (pencarian lokasi) ────────────────────────
BINDERBYTE_API_KEY=

# ── GoHighLevel Webhooks (opsional) ─────────────────────────
GHL_REGISTRATION_WEBHOOK_URL=
GHL_REGISTRATION_WEBHOOK_TOKEN=
GHL_QR_WEBHOOK_URL=
GHL_QR_WEBHOOK_TOKEN=

# ── Meta Pixel (Facebook Pixel) ──────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=
